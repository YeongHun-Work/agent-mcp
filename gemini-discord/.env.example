# ─── .env.example ────────────────────────────────────────────────────────────
# 이 파일을 복사하여 .env 로 이름을 변경한 뒤 값을 채워 넣으세요.
#   cp .env.example .env
#
# .env 파일은 절대 Git에 커밋하지 마세요! (.gitignore 에 추가 필수)
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord 봇 ────────────────────────────────────────────────────────────────
# Discord Developer Portal > Bot > Token 에서 확인
DISCORD_TOKEN=

# Discord 애플리케이션(봇) ID
# Discord Developer Portal > General Information > Application ID 에서 확인
CLIENT_ID=

# (옵션) 슬래시 명령어를 등록할 길드(서버) ID
# - 값이 있으면: 해당 길드에만 즉시 등록 (개발/테스트 시 권장)
# - 비워두면:   전역(Global) 등록 — 모든 서버에 적용되나 반영까지 최대 1시간 소요
GUILD_ID=
