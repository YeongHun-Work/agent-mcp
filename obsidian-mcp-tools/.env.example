# 통신 방식: "stdio" 또는 "sse"
MCP_TRANSPORT=stdio

# SSE 서버 포트 (MCP_TRANSPORT=sse 일 때 사용)
SSE_PORT=8000

# Obsidian Local REST API 키 (Settings -> Local REST API 에서 확인 가능)
OBSIDIAN_API_KEY=your_api_key_here

# Obsidian Local REST API Base URL
# 주의: Docker에서 Host PC(Windows)의 Obsidian으로 접속해야 하므로 127.0.0.1 대신 host.docker.internal을 사용합니다.
OBSIDIAN_BASE_URL=https://host.docker.internal:27124

# 저장될 기본 대상 폴더 (비워두면 Vault 최상단에 저장됩니다)
OBSIDIAN_TARGET_FOLDER=Memo
